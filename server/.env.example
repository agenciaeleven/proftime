# Porta (Railway injeta PORT automaticamente)
PORT=3001

# URL pública do serviço (ex: https://proftime-api.up.railway.app)
PUBLIC_URL=https://seu-servico.up.railway.app

# Origens permitidas (Vercel frontend), separadas por vírgula
CORS_ORIGIN=http://localhost:5173,https://seu-app.vercel.app

# Google AI Studio — tier gratuito: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gamma — geração de slides: https://developers.gamma.app
GAMMA_API_KEY=

# Autenticação JWT (obrigatório em produção)
JWT_SECRET=

# Chave para cadastro interno de professores (POST /auth/internal/register)
ADMIN_SECRET=

# Professor inicial (criado se o banco estiver vazio)
SEED_TEACHER_EMAIL=professor@proftime.com.br
SEED_TEACHER_PASSWORD=ProfTime@2026

# PostgreSQL (Railway) — base de conhecimento + auth
DATABASE_URL=

# Cadastro interno de professores (CLI):
# npm run db:create-user -- --email EMAIL --password SENHA --name "Nome Completo"
